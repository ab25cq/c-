#include <stdio.h>

static int last_a;
static int last_b;
static int last_c;

void fun(int a = b + 1, int b = 22, int c = 33);

void fun(int a = b + 1, int b = 22, int c = 33)
{
    last_a = a;
    last_b = b;
    last_c = c;
}

int main(void)
{
    int b = 111;

    fun();
    if (last_a != 112 || last_b != 22 || last_c != 33) {
        return 1;
    }

    fun(c: 9, a: 7);
    if (last_a != 7 || last_b != 22 || last_c != 9) {
        return 2;
    }

    fun(1, c: 3);
    if (last_a != 1 || last_b != 22 || last_c != 3) {
        return 3;
    }

    return 0;
}
