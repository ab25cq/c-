#include <stdlib.h>

struct Holder {
    owned int* value;
};

int main(void)
{
    int* owned_value = new int;
    struct Holder holder;

    owned_value = new int;
    holder.value = new int;
    holder.value = new int;

    if (owned_value == NULL || holder.value == NULL) {
        return 1;
    }
    return 0;
}
