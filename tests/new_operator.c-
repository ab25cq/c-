#include <stdlib.h>

struct Item {
    int value;
};

int main(void)
{
    int* owned_value = new int;
    struct Item* item = new struct Item;

    if (owned_value == NULL || item == NULL) {
        return 1;
    }
    *owned_value = 3;
    if (*owned_value != 3 || item->value != 0) {
        return 2;
    }
    return 0;
}
