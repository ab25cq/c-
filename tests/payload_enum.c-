#include <stdio.h>

#define xassert(name, cond) do { if (!(cond)) { puts(name); return 1; } } while (0)

enum Option<T> {
    Some(T),
    None,
};

int main(void)
{
    auto some = new Option<int>.Some(123);
    auto none = new Option<int>.None();

    xassert("some", some.is_Some());
    xassert("none", none.is_None());
    xassert("payload", some.get_Some() == 123);
    return 0;
}
